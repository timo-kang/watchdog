{
  "poll_interval": "2s",
  "incident_dir": "./var/incidents",
  "log_transitions_only": true,
  "sources": {
    "host": {
      "enabled": false
    },
    "module_reports": {
      "enabled": false,
      "socket_path": "./var/run/watchdog/module.sock",
      "max_message_bytes": 4096,
      "default_stale_after": "5s"
    },
    "systemd": {
      "enabled": true,
      "units": [
        {
          "name": "systemd-journald.service",
          "source_id": "journald",
          "require_main_pid": true
        }
      ]
    }
  },
  "rules": {
    "host": {
      "max_cpu_temp_warn_c": 85,
      "max_cpu_temp_critical_c": 95,
      "max_temp_warn_c": 90,
      "max_temp_critical_c": 100,
      "mem_available_warn_mb": 1024,
      "mem_available_critical_mb": 512,
      "load_ratio_warn": 1.0,
      "load_ratio_critical": 1.5
    },
    "process": {
      "restart_warn": 1,
      "restart_fail": 3
    }
  }
}
