{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "watchdog-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "ok"
                },
                "1": {
                  "text": "warn"
                },
                "2": {
                  "text": "fail"
                },
                "3": {
                  "text": "stale"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "watchdog_snapshot_overall_code",
          "refId": "A"
        }
      ],
      "title": "Watchdog Overall",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "watchdog-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "none"
                },
                "1": {
                  "text": "notify"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "2 * watchdog_supervisor_overall_action{action=\"degrade\"} + 3 * watchdog_supervisor_overall_action{action=\"safe_stop\"} + watchdog_supervisor_overall_action{action=\"notify\"}",
          "refId": "A"
        }
      ],
      "title": "Supervisor Action",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "watchdog-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "watchdog_supervisor_active_components",
          "refId": "A"
        }
      ],
      "title": "Active Components",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "watchdog-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "watchdog_component_severity_code",
          "legendFormat": "{{component_id}}",
          "refId": "A"
        }
      ],
      "title": "Component Severity",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "watchdog-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "watchdog_status_metric_value{metric_name=\"time.unsynchronized_for_s\"}",
          "legendFormat": "{{source_id}} unsynchronized",
          "refId": "A"
        },
        {
          "expr": "watchdog_status_metric_value{metric_name=~\"age.s|age_s\"}",
          "legendFormat": "{{source_id}} age",
          "refId": "B"
        }
      ],
      "title": "Freshness and Time Sync",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "watchdog-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "watchdog_status_metric_value{metric_name=\"storage.used_percent\"}",
          "legendFormat": "{{source_id}} used",
          "refId": "A"
        },
        {
          "expr": "watchdog_status_metric_value{metric_name=\"storage.busy_percent\"}",
          "legendFormat": "{{source_id}} busy",
          "refId": "B"
        }
      ],
      "title": "Storage Pressure",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "watchdog-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "watchdog_collector_last_duration_seconds",
          "legendFormat": "{{collector}}",
          "refId": "A"
        }
      ],
      "title": "Collector Duration",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "watchdog-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "id": 8,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (requested_action, result) (rate(watchdog_supervisor_requests_total[5m]))",
          "legendFormat": "{{requested_action}} {{result}}",
          "refId": "A"
        }
      ],
      "title": "Supervisor Request Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "watchdog",
    "robotics"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "",
  "title": "Watchdog Overview",
  "version": 1
}
